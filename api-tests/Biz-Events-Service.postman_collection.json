  "item": [
    {
      "name": "CIE-searchTransaction - Success",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"BizEvents-Service SearchTransaction - Status code is 200 with valid json response\", function () {\r",
              "    pm.response.to.have.status(200);\r",
              "    const response = pm.response.json();\r",
              "    pm.expect(response.subject).to.be.a(\"string\").and.not.empty;\r",
              "    pm.expect(response.amount).to.exist;\r",
              "    pm.expect(response.payee).to.be.an(\"object\");\r",
              "    pm.expect(response.payee.name).to.be.a(\"string\").and.not.empty;\r",
              "    pm.expect(response.payee.taxCode).to.be.a(\"string\").and.not.empty;\r",
              "    pm.expect(response.debtor).to.be.an(\"object\");\r",
              "    pm.expect(response.debtor.name).to.be.a(\"string\").and.not.empty;\r",
              "    pm.expect(response.debtor.taxCode).to.be.a(\"string\").and.not.empty;\r",
              "    pm.expect(response.refNumberValue).to.be.a(\"string\").and.not.empty;\r",
              "    pm.expect(response.refNumberType).to.be.a(\"string\").and.not.empty;\r",
              "});"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "x-fiscal-code",
            "value": "{{X-FISCAL-CODE}}",
            "type": "text"
          },
          {
            "key": "Authorization",
            "value": "Bearer {{TOKEN}}",
            "type": "text"
          }
        ],
        "url": {
          "raw": "{{HOSTNAME}}/searchtransactions/v1/transactions/organizations/{{CF-ORG}}/notices/{{NAV}}",
          "host": [
            "{{HOSTNAME}}"
          ],
          "path": [
            "searchtransactions",
            "v1",
            "transactions",
            "organizations",
            "{{CF-ORG}}",
            "notices",
            "{{NAV}}"
          ]
        }
      },
      "response": []
